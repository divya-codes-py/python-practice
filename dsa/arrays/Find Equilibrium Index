# Problem: Find index where left sum equals right sum
# Interview Question: "Where can you split the list so both sides balance?"

def find_equilibrium(numbers):
    total = sum(numbers)
    left_sum = 0

    for i in range(len(numbers)):
        right_sum = total - left_sum - numbers[i]

        if left_sum == right_sum:
            return i

        left_sum += numbers[i]

    return -1


# Test
nums = [1, 3, 5, 2, 2]
result = find_equilibrium(nums)

print(f"List: {nums}")
print(f"Equilibrium index: {result}")
print(f"Left sum: {sum(nums[:result])}")
print(f"Right sum: {sum(nums[result+1:])}")
